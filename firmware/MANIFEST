## Prebuilt slave firmware images
##
## Each binary is a single merged image (bootloader + partition table +
## ota_data + network_adapter), flashable to offset 0x0 via
##   firmware/flash.sh <port> <chip>
## CI rebuilds these on every push and attaches them to release tags.

[c5_slave_merged.bin]
chip:        esp32c5                                         # Wi-Fi 6 + BLE; 2.4 + 5 GHz
flash-at:    0x0
sha256:      c630c03bc2a04ca90da06d42def1ebf25fad9d0d95c9bf89ae87cd254bc521b0

[c6_slave_merged.bin]
chip:        esp32c6                                         # Wi-Fi 6 + BLE + 802.15.4; 2.4 GHz only
flash-at:    0x0
sha256:      c91ab2e73484b5cb7ef2d6244f65713d1cad55182b06348f4e269743d8b9d4c3

## Common flash settings (passed by flash.sh):
##   flash-size:  4 MB
##   flash-mode:  dio
##   flash-freq:  80 MHz
##
## Source: this repo's slave/ project against ESP-IDF v6.0.
## Upstream: https://github.com/espressif/esp-hosted-mcu @ f99ee55aea93ab671d9849bd962aa2f10d01f7d5

## What's enabled per chip
##
## C5  — radio-side knobs available:
##         channel/freq/band, 802.11p PHY mode, RX gain, AGC, CCA + counters,
##         TX power, low-rate filter, bandwidth, RSSI, noise floor, temperature,
##         CSI dump, internal loopback, BT-radio TX gain.
##         802.11p / 5.9 GHz: phy_11p_set armed at boot, channel = CCH (180).
##         IEEE154 RPCs return NOT_SUPPORTED (no 802.15.4 silicon).
##
## C6  — radio-side knobs available:
##         channel/freq/band (2.4 GHz only), 802.11p PHY mode, RX gain, AGC,
##         CCA + counters, TX power, low-rate filter, RSSI, noise floor.
##         IEEE154 RPCs ENABLED (Thread / Zigbee co-processor).
##         802.11p RPCs accept the call but the waveform is 2.4 GHz only —
##         bench-only, not a real V2X solution.
